# ═══════════════════════════════════════════════
# Media Forge Platform — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values
# All vars prefixed MF_ to avoid clashes with other projects

# --- Port Prefix -----------------------------
# Two-digit prefix for all host-side ports.
# Default 40 -> gateway=4000, user-svc=4001, pg-user=4033, redis=4079, etc.
# Change to another value (e.g. 50) to run alongside other projects.
MF_PORT_PREFIX=40

# --- General ----------------------------------
MF_NODE_ENV=development

# --- JWT --------------------------------------
MF_JWT_SECRET=your-secret-key-change-me
MF_JWT_EXPIRES_IN=15m
MF_JWT_REFRESH_EXPIRES_IN=7d

# --- PostgreSQL -------------------------------
MF_PG_USER_PASS=changeme
MF_PG_UPLOAD_PASS=changeme
MF_PG_CATALOG_PASS=changeme
MF_PG_TRANSCODE_PASS=changeme
MF_PG_AI_PASS=changeme

# --- MinIO (S3-compatible) --------------------
MF_MINIO_ACCESS_KEY=minioadmin
MF_MINIO_SECRET_KEY=minioadmin

# --- CDN / Streaming -------------------------
MF_CDN_BASE_URL=https://cdn.yourdomain.com
MF_CDN_SIGNING_KEY=your-cdn-signing-key

# --- AI Service -------------------------------
MF_WHISPER_MODEL=medium
MF_YOLO_MODEL=yolov8n

# --- Notification -----------------------------
MF_SENDGRID_API_KEY=your-sendgrid-key
MF_SMTP_HOST=
MF_SMTP_PORT=587
MF_SMTP_USER=
MF_SMTP_PASS=
